// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String       @id @default(uuid())
  userAgent String?
  ip        String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  events    TrackEvent[]
}

model TrackEvent {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType   String   // PAGE_VIEW, PRODUCT_CLICK, PRODUCT_VIEW, TIME_SPENT, FORM_SUBMIT, WHATSAPP_CLICK
  productName String?
  pageName    String
  duration    Int?     // in seconds
  metadata    String?  // custom details
  timestamp   DateTime @default(now())

  @@index([sessionId])
}

model Product {
  id          String   @id
  name        String
  category    String   // new-arrivals, best-sellers, bridal, daily-wear
  subCategory String
  price       Float
  rating      Float
  image       String
  description String
  materials   String
  details     String   // comma-separated list of details
}

model StoreSettings {
  id             String @id @default("active_config")
  ownerName      String @default("Mr. Yogesh Kumar Gupta")
  storeName      String @default("Omar Jewellers OJ")
  contactPhone   String @default("+91 99364 88845")
  contactEmail   String @default("Swayamomar123@gmail.com")
  addressText    String @default("Chowk, Shahabad, Hardoi, Uttar Pradesh, India")
  whatsappNumber String @default("9936488845")
}

model CustomContent {
  key   String @id
  value String
}
